generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

model User {
  id                Int      @id @default(autoincrement())
  username          String   @unique @db.VarChar(50)
  email             String?  @unique @db.VarChar(100)
  phone             String?  @unique @db.VarChar(20)
  password          String   @db.VarChar(255)
  realName          String?  @map("real_name") @db.VarChar(50)
  nickName          String?  @map("nick_name") @db.VarChar(50)
  avatar            String?  @db.VarChar(500)
  gender            String?  @default("unknown") @db.VarChar(10)
  birthday          DateTime? @db.Date
  employeeNo        String?  @unique @map("employee_no") @db.VarChar(50)
  jobTitle          String?  @map("job_title") @db.VarChar(50)
  isSuperAdmin      Boolean  @default(false) @map("is_super_admin")
  status            String   @default("active") @db.VarChar(20)
  lastLoginAt       DateTime? @map("last_login_at")
  lastLoginIp       String?  @map("last_login_ip") @db.VarChar(50)
  loginFailCount    Int      @default(0) @map("login_fail_count")
  passwordChangedAt DateTime? @map("password_changed_at")
  mfaSecret         String?  @map("mfa_secret") @db.VarChar(255)
  mfaEnabled        Boolean  @default(false) @map("mfa_enabled")
  mfaBackupCodes    String?  @map("mfa_backup_codes") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  userRoles         UserRole[]
  userOrganizations UserOrganization[]
  userPosts         UserPost[]
  oauths            UserOAuth[]
  files             File[]
  refreshTokens     RefreshToken[]
  tenantMembers     TenantMember[]

  @@map("tds_users")
}

model Role {
  id                      Int      @id @default(autoincrement())
  name                    String   @db.VarChar(50)
  code                    String   @unique @db.VarChar(50)
  description             String?  @db.VarChar(255)
  type                    String   @default("custom") @db.VarChar(20)
  level                   Int      @default(1)
  status                  String   @default("active") @db.VarChar(20)
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at")

  userRoles               UserRole[]
  rolePermissions         RolePermission[]
  roleApiPermissions      RoleApiPermission[]
  roleDataPermissionScopes RoleDataPermissionScope[]
  roleResourceConfigs     RoleResourceConfig[]

  @@map("tds_roles")
}

model Permission {
  id              Int      @id @default(autoincrement())
  pid             Int      @default(0)
  code            String   @unique @db.VarChar(100)
  type            String   @default("menu") @db.VarChar(20)
  name            String?  @db.VarChar(100)
  path            String?  @db.VarChar(255)
  component       String?  @db.VarChar(255)
  redirect        String?  @db.VarChar(255)
  handle          Json?
  sortOrder       Int      @default(0) @map("sort_order")
  isSensitive     Boolean  @default(false) @map("is_sensitive")
  status          String   @default("active") @db.VarChar(20)
  isBuiltIn       Boolean  @default(false) @map("is_built_in")
  description     String?  @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("tds_permissions")
}

model Organization {
  id              Int      @id @default(autoincrement())
  parentId        Int?     @map("parent_id")
  code            String   @unique @db.VarChar(64)
  name            String   @db.VarChar(100)
  type            String   @default("department") @db.VarChar(20)
  leaderId        Int?     @map("leader_id")
  sortOrder       Int      @default(0) @map("sort_order")
  description     String?  @db.VarChar(255)
  status          String   @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  userOrganizations UserOrganization[]

  @@map("tds_organizations")
}

model UserRole {
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("tds_user_roles")
}

model RolePermission {
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("tds_role_permissions")
}

model UserOrganization {
  userId         Int      @map("user_id")
  organizationId Int      @map("organization_id")
  isPrimary      Boolean  @default(true) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@map("tds_user_organizations")
}

model File {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  originalName String   @map("original_name") @db.VarChar(255)
  fileName     String   @map("file_name") @db.VarChar(255)
  path         String   @db.VarChar(500)
  url          String   @db.VarChar(500)
  storageType  String   @map("storage_type") @db.VarChar(20)
  size         Int
  mimeType     String   @map("mime_type") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tds_files")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tds_refresh_tokens")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  serviceName  String   @default("user-service") @map("service_name") @db.VarChar(50)
  eventType    String   @default("http") @map("event_type") @db.VarChar(20)
  userId       Int?     @map("user_id")
  action       String   @db.VarChar(255)
  resource     String   @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.VarChar(100)
  ip           String?  @db.VarChar(50)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  statusCode   Int?     @map("status_code")
  duration     Int?
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("tds_audit_logs")
}

model DataPermissionMeta {
  id                    Int      @id @default(autoincrement())
  resourceCode          String   @unique @map("resource_code") @db.VarChar(100)
  resourceName          String   @map("resource_name") @db.VarChar(100)
  entity                String   @db.VarChar(100)
  treeStrategy          String   @default("NONE") @map("tree_strategy") @db.VarChar(32)
  visibleScope          Json     @map("visible_scope")
  operateScopes         Json     @map("operate_scopes")
  createOwnershipFields Json?    @map("create_ownership_fields")
  supportedActions      Json     @map("supported_actions")
  supportedDimensions   Json     @map("supported_dimensions")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tds_data_permission_resource_meta")
}

model RoleDataPermissionScope {
  id           Int      @id @default(autoincrement())
  roleId       Int      @map("role_id")
  resourceCode String   @map("resource_code") @db.VarChar(100)
  action       String   @default("view") @db.VarChar(20)
  scope        String   @default("ORG") @db.VarChar(20)
  dimension    String   @default("DEPT") @db.VarChar(20)
  customTargets Json?   @map("custom_org_ids")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceCode, action])
  @@map("tds_role_data_permission_scopes")
}

model RoleResourceConfig {
  id           Int      @id @default(autoincrement())
  roleId       Int      @map("role_id")
  resourceCode String   @map("resource_code") @db.VarChar(100)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceCode])
  @@map("tds_role_resource_configs")
}

model ApiPermission {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(100)
  module      String   @db.VarChar(50)
  category    String?  @db.VarChar(50)
  method      String   @db.VarChar(10)
  path        String   @db.VarChar(200)
  description String?  @db.Text
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  roleApiPermissions RoleApiPermission[]

  @@map("tds_api_permissions")
}

model RoleApiPermission {
  roleId          Int      @map("role_id")
  apiPermissionId Int      @map("api_permission_id")
  createdAt       DateTime @default(now()) @map("created_at")

  role            Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  apiPermission   ApiPermission @relation(fields: [apiPermissionId], references: [id], onDelete: Cascade)

  @@id([roleId, apiPermissionId])
  @@map("tds_role_api_permissions")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  username  String?  @db.VarChar(50)
  ip        String?  @db.VarChar(50)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  location  String?  @db.VarChar(100)
  status    String   @default("success") @db.VarChar(20)
  message   String?  @db.VarChar(255)
  loginType String   @default("password") @map("login_type") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tds_login_logs")
  @@index([userId])
  @@index([createdAt])
}

model PasswordPolicy {
  id                Int      @id @default(autoincrement())
  minLength         Int      @default(8) @map("min_length")
  maxLength         Int      @default(32) @map("max_length")
  requireUppercase  Boolean  @default(true) @map("require_uppercase")
  requireLowercase  Boolean  @default(true) @map("require_lowercase")
  requireNumbers    Boolean  @default(true) @map("require_numbers")
  requireSymbols    Boolean  @default(false) @map("require_symbols")
  expiryDays        Int      @default(90) @map("expiry_days")
  historyCount      Int      @default(5) @map("history_count")
  maxLoginAttempts  Int      @default(5) @map("max_login_attempts")
  lockoutDuration   Int      @default(30) @map("lockout_duration")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tds_password_policies")
}

model PasswordHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tds_password_histories")
  @@index([userId])
}

model Post {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(50)
  level       Int      @default(1)
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("active") @db.VarChar(20)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  userPosts   UserPost[]

  @@map("tds_posts")
}

model UserPost {
  userId    Int      @map("user_id")
  postId    Int      @map("post_id")
  isPrimary Boolean  @default(true) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("tds_user_posts")
}

model DictType {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(50)
  description String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  dictData    DictData[]

  @@map("tds_dict_types")
}

model DictData {
  id        Int      @id @default(autoincrement())
  dictId    Int      @map("dict_id")
  label     String   @db.VarChar(50)
  value     String   @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  status    String   @default("active") @db.VarChar(20)
  remark    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  dictType  DictType @relation(fields: [dictId], references: [id], onDelete: Cascade)

  @@map("tds_dict_data")
  @@index([dictId])
}

model SysConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  type        String   @default("string") @db.VarChar(20)
  group       String   @default("system") @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  isBuiltIn   Boolean  @default(false) @map("is_built_in")
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tds_sys_configs")
}

model UserOAuth {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  provider     String   @db.VarChar(20)
  providerId   String   @map("provider_id") @db.VarChar(100)
  unionId      String?  @map("union_id") @db.VarChar(100)
  accessToken  String?  @map("access_token") @db.VarChar(500)
  refreshToken String?  @map("refresh_token") @db.VarChar(500)
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("tds_user_oauths")
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  content     String   @db.Text
  type        String   @default("system") @db.VarChar(20)
  isTop       Boolean  @default(false) @map("is_top")
  isPopup     Boolean  @default(false) @map("is_popup")
  startAt     DateTime @map("start_at")
  endAt       DateTime? @map("end_at")
  targetRoles String[] @map("target_roles")
  status      String   @default("published") @db.VarChar(20)
  createdBy   String   @map("created_by") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tds_notices")
  @@index([status, startAt, endAt])
}

model NoticeRead {
  id        Int      @id @default(autoincrement())
  noticeId  Int      @map("notice_id")
  userId    Int      @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  @@unique([noticeId, userId])
  @@map("tds_notice_reads")
  @@index([userId])
}

model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int?     @map("sender_id")
  receiverId  Int      @map("receiver_id")
  type        String   @default("system") @db.VarChar(20)
  title       String   @db.VarChar(100)
  content     String   @db.Text
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("tds_messages")
  @@index([receiverId, isRead])
  @@index([createdAt])
}

model ApiKey {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String   @db.VarChar(100)
  key         String   @unique @db.VarChar(255)
  secret      String   @db.VarChar(255)
  permissions String[] @default([])
  rateLimit   Int      @default(1000) @map("rate_limit")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tds_api_keys")
  @@index([userId])
  @@index([key])
}

model Webhook {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String   @db.VarChar(100)
  url         String   @db.VarChar(500)
  secret      String   @db.VarChar(255)
  events      String[] @default([])
  status      String   @default("active") @db.VarChar(20)
  lastTriggeredAt DateTime? @map("last_triggered_at")
  failCount   Int      @default(0) @map("fail_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tds_webhooks")
  @@index([userId])
  @@index([status])
}

model Tenant {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(20)
  maxUsers    Int      @default(100) @map("max_users")
  maxStorage  Int      @default(1073741824) @map("max_storage")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  members     TenantMember[]

  @@map("tds_tenants")
}

model TenantMember {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  userId    Int      @map("user_id")
  role      String   @default("member") @db.VarChar(20)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tds_tenant_members")
  @@index([userId])
}
