{
  "name": "data-space",
  "version": "0.0.1",
  "description": "Enterprise-grade NestJS monorepo backend scaffold",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build user-service",
    "build:worker": "nest build worker",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start user-service",
    "start:dev": "nest start user-service --watch",
    "start:worker:dev": "nest start worker --watch",
    "start:debug": "nest start user-service --debug --watch",
    "start:prod": "node dist/apps/user-service/main",
    "start:worker:prod": "node dist/apps/worker/main",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "cross-env NODE_OPTIONS=--experimental-require-module npx prisma migrate dev",
    "db:generate": "cross-env NODE_OPTIONS=--experimental-require-module npx prisma generate",
    "db:studio": "cross-env NODE_OPTIONS=--experimental-require-module npx prisma studio"
  },
  "dependencies": {
    "@anatine/zod-openapi": "^2.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.6.0",
    "@types/js-yaml": "^4.0.9",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "chalk": "4",
    "dotenv": "^17.4.2",
    "effect": "^3.21.2",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.1",
    "mariadb": "^3.4.0",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.8.0",
    "prisma": "6.6.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "svg-captcha": "^1.4.0",
    "ua-parser-js": "^2.0.9",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-oauth2": "^1.8.0",
    "@types/supertest": "^6.0.0",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^9.0.8",
    "@types/xlsx": "^0.0.36",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@core/(.*)$": "<rootDir>/libs/core/src/$1",
      "^@core$": "<rootDir>/libs/core/src",
      "^@shared/(.*)$": "<rootDir>/libs/shared/src/$1",
      "^@shared$": "<rootDir>/libs/shared/src"
    }
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@prisma/client"
    ]
  }
}
